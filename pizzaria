            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            margin-bottom: 10px;
            position: relative;
        }

        .section-subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 40px;
            font-size: 16px;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 3px;
            background-color: #e74c3c;
            margin: 10px auto 0;
        }

        .category-title {
            font-size: 22px;
            color: #c0392b;
            margin: 30px 0 15px 0;
            border-left: 4px solid #e74c3c;
            padding-left: 10px;
        }

